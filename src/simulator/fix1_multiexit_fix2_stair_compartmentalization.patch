+            if (s == null) continue;
+            for (int i = 0; i < 4; i++) {
+                int ny = s.y + dy[i], nx = s.x + dx[i];
+                if (ny <= 0 || ny >= rows - 1 || nx <= 0 || nx >= cols - 1) continue;
+                if (!(obj[s.z][ny][nx] instanceof Floor)) continue;
+                FireDoor fd = new FireDoor();
+                fd.isOpen = false;
+                obj[s.z][ny][nx] = fd;
+                s.enclosureDoor = fd;
+                break;
+            }
+        }
+    }
